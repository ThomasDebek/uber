<header class="navbar navbar-expand-lg navbar-light" style="background-color: #e3f2fd;">
  <div class="container">
    <!-- Logo -->
    <%= link_to "Product", root_path, id: "logo", class: "navbar-brand" %>

    <!-- Navbar Toggler (for mobile) -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar Links -->
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        <!-- User info if logged in -->
        <% if user_signed_in? %>
          <li class="nav-item">
            <span class="navbar-text">
              Logged in as <strong><%= current_user.email %></strong>
            </span>
          </li>
          <li class="nav-item">
            <%= link_to 'Edit profile', edit_user_registration_path, class: "btn btn-link" %>
          </li>
          <li class="nav-item">
            <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "btn btn-link", data: { confirm: 'Are you sure?' } %>
          </li>
        <% else %>
          <!-- Links for unauthenticated users -->
          <li class="nav-item">
            <%= link_to "Sign up", new_user_registration_path, class: "btn btn-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Login", new_user_session_path, class: "btn btn-link" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</header>