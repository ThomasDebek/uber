<% content_for :title, "Products" %>

<div class="container mt-4">
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">Products</h1>
    <%= link_to "New Product", new_product_path, class: "btn btn-primary" %>
  </div>

  <% if @products.any? %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% @products.each do |product| %>
        <div class="col">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <%= render product %>
            </div>
            <div class="card-footer d-flex justify-content-between">
              <%= link_to "Show", product, class: "btn btn-outline-secondary" %>
              <%= link_to "Edit", edit_product_path(product), class: "btn btn-outline-primary" %>
              <%= button_to "Destroy", product, method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Are you sure?" } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted mt-4">No products found.</p>
  <% end %>
</div>