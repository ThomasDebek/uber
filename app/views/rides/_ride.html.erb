<div id="<%= dom_id ride %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Pickup location:</strong>
    <%= ride.pickup_location %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Dropoff location:</strong>
    <%= ride.dropoff_location %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Customer:</strong>
    <%= ride.customer_id %>
  </div>

  <div>
    <strong class="block font-medium mb-1">Status:</strong>
    <%= ride.status %>
  </div>

</div>
