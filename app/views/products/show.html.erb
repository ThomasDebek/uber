<% content_for :title, @product.name %>

<div class="max-w-3xl mx-auto mt-10 px-4">
  <% if notice.present? %>
    <div class="mb-6 rounded-md bg-green-100 border border-green-300 text-green-800 px-4 py-3 relative">
      <%= notice %>
      <button type="button" class="absolute top-2 right-2 text-green-600 hover:text-green-800" onclick="this.parentElement.remove()">✕</button>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <%= render @product %>
  </div>

  <div class="flex flex-wrap gap-4">
    <%= link_to "Edit this product", edit_product_path(@product),
                class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>

    <%= link_to "Back to products", products_path,
                class: "bg-gray-100 text-gray-800 px-4 py-2 rounded hover:bg-gray-200" %>

    <%= link_to "Destroy this product", @product,
                method: :delete,
                data: { confirm: "Are you sure?" },
                class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700" %>
  </div>
</div>