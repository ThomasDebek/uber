<% content_for :title, "Products" %>

<div class="max-w-7xl mx-auto mt-10 px-4">
  <% if notice.present? %>
    <div class="mb-6 rounded-md bg-green-100 border border-green-300 text-green-800 px-4 py-3 relative">
      <%= notice %>
      <button type="button" class="absolute top-2 right-2 text-green-600 hover:text-green-800" onclick="this.parentElement.remove()">✕</button>
    </div>
  <% end %>

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold text-gray-800">Products</h1>
    <%= link_to "New Product", new_product_path, class: "bg-blue-600 text-white px-4 py-2 rounded-md shadow hover:bg-blue-700" %>
  </div>

  <% if @products.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @products.each do |product| %>
        <div class="bg-white rounded-lg shadow-md flex flex-col justify-between h-full p-4">
          <div>
            <%= render product %>
          </div>
          <div class="flex justify-between items-center mt-4 space-x-2">
            <%= link_to "Show", product, class: "text-sm text-gray-700 border border-gray-300 rounded px-3 py-1 hover:bg-gray-100" %>
            <%= link_to "Edit", edit_product_path(product), class: "text-sm text-blue-700 border border-blue-300 rounded px-3 py-1 hover:bg-blue-100" %>
            <%= button_to "Destroy", product, method: :delete,
                          data: { turbo_confirm: "Are you sure?" },
                          class: "text-sm text-red-700 border border-red-300 rounded px-3 py-1 hover:bg-red-100" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-gray-500 mt-6">No products found.</p>
  <% end %>
</div>