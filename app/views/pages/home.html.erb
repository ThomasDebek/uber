<div class="w-full min-h-[100vh] bg-indigo-500 flex flex-col items-center pt-36">
  <h1 class="font-bold text-6xl">Dupper</h1>
  <p class="text-lg mt-2">A ride sharing app built with Ruby on Rails and Hotwire</p>

  <% if current_customer %>
    <%= link_to "New Ride", "#", class: "bg-blue-500 text-blue-50 p-2 rounded-lg" %>
  <% else  %>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-4 mt-6">
        <%= link_to "Sign up as User", new_user_registration_path, class: "bg-green-500 text-lg p-2 rounded-lg text-gray-100" %>
        <%= link_to "Sign up as Customer", new_customer_registration_path, class: "bg-blue-500 text-lg p-2 rounded-lg text-gray-100" %>
        <%= link_to "Sign up as Driver", new_driver_registration_path, class: "bg-green-500 text-lg p-2 rounded-lg text-gray-100" %>
      </div>
    </div>
  <% end %>


</div>